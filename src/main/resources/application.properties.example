spring.datasource.url=jdbc:mysql://localhost:3306/dms
spring.datasource.username=YOUR_DATABASE_USERNAME
spring.datasource.password=YOUR_DATABASE_PASSWORD

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

spring.security.user.name=YOUR_SECURITY_USERNAME
spring.security.user.password=YOUR_SECURITY_PASSWORD

spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

jwt.secret=REPLACE_WITH_A_SECRET_OF_AT_LEAST_32_CHARACTERS